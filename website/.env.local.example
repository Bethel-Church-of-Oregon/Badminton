# Copy this file to .env.local and fill in the values.
# Run `vercel env pull .env.local` after linking your project to pull Vercel Postgres vars automatically.

# Vercel Postgres (auto-populated by `vercel env pull`)
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Admin password for the leaderboard admin panel
ADMIN_PASSWORD=admin
